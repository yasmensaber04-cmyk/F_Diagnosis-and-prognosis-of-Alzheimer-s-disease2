def load_tadpole(csv_path: str = '/content/TADPOLE_D1_D2.csv') -> pd.DataFrame:
    """Load TADPOLE_D1_D2.csv with enhanced cleaning."""
    print(f"[LOAD] Reading {csv_path} ...")
    df = pd.read_csv(csv_path, low_memory=False)
    print(f"[LOAD] Raw shape: {df.shape}")

    if 'Month' in df.columns:
        df['Month_num'] = pd.to_numeric(df['Month'], errors='coerce')
    else:
        df['Month_num'] = df['VISCODE'].apply(viscode_to_month)

    df = df.dropna(subset=['Month_num'])
    df['Month_num'] = df['Month_num'].astype(int)

    if 'DX' in df.columns:
        df['DX_clean'] = df['DX'].astype(str).str.strip().map(DX_MAP)
    else:
        df['DX_clean'] = np.nan

    if 'DX_bl' in df.columns:
        mask = df['DX_clean'].isna()
        df.loc[mask, 'DX_clean'] = df.loc[mask, 'DX_bl'].astype(str).str.strip().map(DX_MAP)

    df = df.dropna(subset=['DX_clean'])
    df['DX_clean'] = df['DX_clean'].astype(int)

    keep_cols = (['RID', 'VISCODE', 'Month_num'] +
                 STATIC_FEATURES +
                 [c for c in DYNAMIC_FEATURES if c in df.columns] +
                 ['DX_clean'])
    df = df[[c for c in keep_cols if c in df.columns]].copy()
    df = df.rename(columns={'DX_clean': 'DX', 'Month_num': 'Month'})

    for col in STATIC_FEATURES:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce')
            df[col] = df.groupby('RID')[col].transform(lambda x: x.ffill().bfill())
            df[col] = df[col].fillna(df[col].median())

    if 'PTGENDER' in df.columns:
        df['PTGENDER'] = df['PTGENDER'].map({'Female': 1, 'Male': 0, 1: 1, 0: 0, '1': 1, '2': 0}).fillna(0)

    visit_counts = df.groupby('RID')['Month'].nunique()
    valid_pids = visit_counts[visit_counts >= 2].index
    df = df[df['RID'].isin(valid_pids)].reset_index(drop=True)

    # ========== إضافة ميزات تفاعلية ==========
    if 'APOE4' in df.columns and 'Hippocampus' in df.columns:
        df['APOE4_x_Hippocampus'] = df['APOE4'] * df['Hippocampus']
    if 'CDRSB' in df.columns and 'MMSE' in df.columns:
        df['CDRSB_x_MMSE'] = df['CDRSB'] * (30 - df['MMSE'])
    if 'AGE' in df.columns and 'APOE4' in df.columns:
        df['Age_x_APOE4'] = df['AGE'] * df['APOE4']

    print(f"[LOAD] Clean shape: {df.shape}")
    print(f"[LOAD] Patients: {df['RID'].nunique()}")
    print(f"[LOAD] DX dist: {df['DX'].value_counts().sort_index().to_dict()}")
    print(f"[LOAD] Visit range: {df['Month'].min()} – {df['Month'].max()} months")
    return df


