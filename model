class TADPOLEDataset(Dataset):
    def __init__(self, sequences):
        self.samples = list(sequences.values())

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        s = self.samples[idx]
        return dict(
            dynamic=torch.tensor(s['dynamic'], dtype=torch.float32),
            static=torch.tensor(s['static'], dtype=torch.float32),
            dx_seq=torch.tensor(s['dx_seq'], dtype=torch.long),
            months=torch.tensor(s['months'], dtype=torch.float32),
            time_deltas=torch.tensor(s['time_deltas'], dtype=torch.float32),
            mask=torch.ones(s['seq_len'], dtype=torch.float32),
            future_cdrsb=torch.tensor(s['future_cdrsb'], dtype=torch.float32),
            future_dx=torch.tensor(s['future_dx'], dtype=torch.long),
            seq_len=s['seq_len'],
        )


def collate_fn(batch):
    max_T = max(b['seq_len'] for b in batch)
    out = defaultdict(list)
    fc_list = []
    fd_list = []

    for b in batch:
        pad = max_T - b['seq_len']
        out['dynamic'].append(F.pad(b['dynamic'], (0, 0, 0, pad)))
        out['static'].append(b['static'])
        out['dx_seq'].append(F.pad(b['dx_seq'], (0, pad), value=0))
        out['mask'].append(F.pad(b['mask'], (0, pad), value=0))
        out['months'].append(F.pad(b['months'], (0, pad)))
        out['time_deltas'].append(F.pad(b['time_deltas'], (0, pad)))
        
        fc_list.append(F.pad(b['future_cdrsb'], (0, pad), value=float('nan')))
        fd_list.append(F.pad(b['future_dx'], (0, pad), value=-1))

    return dict(
        dynamic=torch.stack(out['dynamic']),
        static=torch.stack(out['static']),
        dx_seq=torch.stack(out['dx_seq']),
        mask=torch.stack(out['mask']),
        months=torch.stack(out['months']),
        time_deltas=torch.stack(out['time_deltas']),
        future_cdrsb=torch.stack(fc_list),
        future_dx=torch.stack(fd_list),
    )


def mixup_data(x, y, alpha=0.2):
    if alpha > 0:
        lam = np.random.beta(alpha, alpha)
    else:
        lam = 1
    batch_size = x.size(0)
    index = torch.randperm(batch_size).to(x.device)
    mixed_x = lam * x + (1 - lam) * x[index]
    y_a, y_b = y, y[index]
    return mixed_x, y_a, y_b, lam


