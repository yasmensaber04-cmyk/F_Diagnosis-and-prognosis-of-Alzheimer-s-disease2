# 11. SMOTE-T
# ─────────────────────────────────────────────────────────────────────────────
def smote_temporal(seqs, target_cls=2, mul=2, noise=0.04):
    minority = {k: v for k, v in seqs.items() if v['dx_seq'][-1] == target_cls}
    n_add = max(0, mul * len(minority) - len(minority))
    keys = list(minority.keys())
    rng = np.random.RandomState(SEED)
    out = dict(seqs)

    for i in range(n_add):
        k1, k2 = rng.choice(keys, 2)
        s1, s2 = minority[k1], minority[k2]
        a = rng.uniform(0.3, 0.7)
        T = min(s1['seq_len'], s2['seq_len'])
        nd = a * s1['dynamic'][:T] + (1 - a) * s2['dynamic'][:T]
        nd += rng.normal(0, noise, nd.shape).astype(np.float32)
        pid = f'syn_{i}'
        out[pid] = dict(
            dynamic=nd, static=a * s1['static'] + (1 - a) * s2['static'],
            dx_seq=s1['dx_seq'][:T].copy(), months=s1['months'][:T].copy(),
            time_deltas=s1['time_deltas'][:T].copy(),
            future_cdrsb=s1['future_cdrsb'][:T].copy(),
            future_dx=s1['future_dx'][:T].copy(),
            seq_len=T, pid=pid
        )
    print(f"[SMOTE-T] Added {n_add} synthetic AD sequences (total: {len(out)})")
    return out


