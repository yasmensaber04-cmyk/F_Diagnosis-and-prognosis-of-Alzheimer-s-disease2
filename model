def viscode_to_month(v):
    if pd.isna(v):
        return np.nan
    v = str(v).strip().lower()
    if v in ('bl', 'sc', 'scmri'):
        return 0
    if v.startswith('m'):
        try:
            return int(v[1:])
        except:
            pass
    return np.nan


