# 13. MAIN FUNCTION
# ─────────────────────────────────────────────────────────────────────────────
def main(csv_path: str = '/content/TADPOLE_D1_D2.csv'):
    print("\n" + "█" * 70)
    print("  IMPROVED TADPOLE FRAMEWORK | Enhanced with All Improvements")
    print("  Tasks: Diagnosis (CN/MCI/AD) + Next-Visit CDRSB Prognosis")
    print("  Metrics: Accuracy | F1 | AUC")
    print("█" * 70)

    df_raw = load_tadpole(csv_path)

    print("\n[STEP 2] Patient-level split (70 / 15 / 15)...")
    pids = df_raw['RID'].unique()
    rng = np.random.RandomState(SEED)
    rng.shuffle(pids)
    n = len(pids)

    tr_pids = set(pids[:int(0.70 * n)])
    va_pids = set(pids[int(0.70 * n):int(0.85 * n)])
    te_pids = set(pids[int(0.85 * n):])

    df_tr = df_raw[df_raw['RID'].isin(tr_pids)].copy()
    df_va = df_raw[df_raw['RID'].isin(va_pids)].copy()
    df_te = df_raw[df_raw['RID'].isin(te_pids)].copy()

    print(f"  Train: {len(tr_pids)} | Val: {len(va_pids)} | Test: {len(te_pids)}")

    print("\n[STEP 3] Advanced preprocessing...")
    prep = AdvancedPreprocessor(max_seq_len=8)

    df_tr_p = prep.fit_transform(df_tr)
    df_va_p = prep.transform(df_va)
    df_te_p = prep.transform(df_te)

    tr_seqs = prep.build_sequences(df_tr_p)
    va_seqs = prep.build_sequences(df_va_p)
    te_seqs = prep.build_sequences(df_te_p)

    print("\n[STEP 4] SMOTE-T oversampling...")
    tr_seqs = smote_temporal(tr_seqs, target_cls=2, mul=2)

    # ========== إنشاء Weighted Sampler لتحسين دقة MCI ==========
    sample_weights = []
    for seq in tr_seqs.values():
        dx_last = seq['dx_seq'][-1]
        if dx_last == 1:  # MCI
            sample_weights.append(3.0)  # وزن 3x لـ MCI
        elif dx_last == 2:  # AD
            sample_weights.append(1.5)  # وزن 1.5x لـ AD
        else:  # CN
            sample_weights.append(1.0)
    
    sampler = WeightedRandomSampler(sample_weights, len(sample_weights))
    
    tr_ld = DataLoader(TADPOLEDataset(tr_seqs), batch_size=32, sampler=sampler, collate_fn=collate_fn, num_workers=0)
    va_ld = DataLoader(TADPOLEDataset(va_seqs), batch_size=32, shuffle=False, collate_fn=collate_fn, num_workers=0)
    te_ld = DataLoader(TADPOLEDataset(te_seqs), batch_size=32, shuffle=False, collate_fn=collate_fn, num_workers=0)

    D_dyn = len(prep.all_dyn)
    D_stat = len(STATIC_FEATURES)

    print(f"\n  Dynamic input dim: {D_dyn}")
    print(f"  Static input dim: {D_stat}")

    all_dx = np.concatenate([s['dx_seq'] for s in tr_seqs.values()])
    counts = np.bincount(all_dx[all_dx >= 0], minlength=3).astype(float)
    cls_w = torch.tensor(1.0 / (counts + 1e-6), dtype=torch.float32).to(DEVICE)
    cls_w /= cls_w.sum() / 3
    print(f"  Class weights: {cls_w.cpu().numpy()}")

    print("\n[STEP 5] Building improved models with Cross-Attention...")
    bilstm = ImprovedBiLSTMModel(D_dyn, D_stat, hidden=128, n_layers=2, dropout=0.3, n_transformer_layers=2).to(DEVICE)
    tcn = ImprovedTCNModel(D_dyn, D_stat, ch=128, ks=3, n_layers=6, dropout=0.3).to(DEVICE)

    print(f"  BiLSTM params: {sum(p.numel() for p in bilstm.parameters()):,}")
    print(f"  TCN params: {sum(p.numel() for p in tcn.parameters()):,}")

    EPOCHS = 80

    print("\n[STEP 6] Training Improved BiLSTM...")
    tr_bilstm = AdvancedTrainer(bilstm, DEVICE, cls_w=cls_w, lr=3e-4, epochs=EPOCHS,
                                patience=20, name='improved_bilstm', use_sam=True, use_mixup=True, accum_steps=4)
    tr_bilstm.fit(tr_ld, va_ld)

    print("\n[STEP 6] Training Improved TCN...")
    tr_tcn = AdvancedTrainer(tcn, DEVICE, cls_w=cls_w, lr=3e-4, epochs=EPOCHS,
                             patience=20, name='improved_tcn', use_sam=True, use_mixup=True, accum_steps=4)
    tr_tcn.fit(tr_ld, va_ld)

    print("\n[STEP 7] Evaluating on test set...")
    eval_bilstm = AdvancedEvaluator(bilstm, DEVICE)
    eval_tcn = AdvancedEvaluator(tcn, DEVICE)

    res_bilstm = eval_bilstm.evaluate(te_ld, mc_samples=20)
    res_tcn = eval_tcn.evaluate(te_ld, mc_samples=20)

    results = {'BiLSTM': res_bilstm, 'TCN': res_tcn}

    for nm, res in results.items():
        print(f"\n  ── {nm} ──")
        print(f"  DIAGNOSIS:")
        print(f"    Accuracy:         {res['accuracy']:.4f}")
        print(f"    Balanced Acc:     {res['balanced_accuracy']:.4f}")
        print(f"    F1-Macro:         {res['f1_macro']:.4f}")
        print(f"    MCC:              {res['mcc']:.4f}")
        print(f"    AUC:              {res['auc']:.4f}")
        print(res['report'])

        print(f"\n  PROGNOSIS (Next-Visit CDRSB Regression):")
        rm = res['reg_metrics']
        print(f"    MAE={rm['MAE']:.3f}  RMSE={rm['RMSE']:.3f}  "
              f"Uncertainty={rm['mean_uncertainty']:.3f}  (n={rm['n_samples']})")

        print(f"\n  PROGNOSIS (Next-Visit Diagnosis):")
        print(f"    Accuracy: {res['prognosis_accuracy']:.3f}")
        print(f"    F1-Macro: {res['prognosis_f1']:.3f}")
        print(f"    AUC:      {res['prognosis_auc']:.3f}")

    print("\n[STEP 8] Generating visualizations...")
    trainers = {'BiLSTM': tr_bilstm, 'TCN': tr_tcn}

    plot_training_curves(trainers)
    plot_calibration_curves(results)
    plot_precision_recall_curves(results)
    plot_regression_metrics(results)
    plot_prognosis_metrics(results)
    df_cmp = plot_comparison_table(results)

    print("\n" + "=" * 70)
    print("  COMPARISON TABLE")
    print("=" * 70)
    print(df_cmp.to_string(index=False))

    print("""
  KEY IMPROVEMENTS INCLUDED:
  ─────────────────────────────────────────────────────────────────────
  ✓ Cubic spline interpolation for missing values
  ✓ Delta features (rate of change)
  ✓ Kalman filtering for trajectory smoothing
  ✓ IQR-based outlier handling
  ✓ Residual LSTM with Transformer encoder
  ✓ Multi-head attention (8 heads)
  ✓ CROSS-ATTENTION between visits (NEW)
  ✓ Layer normalization & GELU activations
  ✓ SAM optimizer for flat minima
  ✓ OneCycleLR scheduler
  ✓ Label smoothing (0.1)
  ✓ MixUp augmentation (α=0.2)
  ✓ Gradient accumulation (4 steps)
  ✓ Monte Carlo Dropout for uncertainty (20 samples)
  ✓ WEIGHTED SAMPLING for MCI class (NEW)
  ✓ ADAPTIVE FOCAL LOSS (gamma_mci=3.0) (NEW)
  ✓ INTERACTION FEATURES (APOE4×Hippocampus, CDRSB×MMSE, Age×APOE4) (NEW)
  ✓ PRECISION-RECALL curves (NEW)
  ✓ PROGNOSIS metrics with F1 & AUC (NEW)
  ✓ Next-visit prediction only (no fixed horizons)
  ✓ Balanced accuracy, MCC, AUC metrics
  ✓ Calibration curves per class
""")

    figs = os.listdir('outputs/figures')
    print(f"[✓] {len(figs)} figures → outputs/figures/")
    print("[✓] Results CSV → outputs/results/comparison_table.csv")
    print("[✓] Model checkpoints → outputs/models/")

    return results, trainers


