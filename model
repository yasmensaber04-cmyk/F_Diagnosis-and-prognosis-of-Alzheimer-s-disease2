        axes[0, 1].plot(tr.vl_acc, label=f'{nm} Val', color=c, lw=2, ls='--')
    for ax, ttl in zip([axes[0, 0], axes[0, 1]], ['Loss', 'Accuracy']):
        ax.set_title(ttl, fontsize=13); ax.set_xlabel('Epoch')
        ax.legend(); ax.grid(alpha=0.3); ax.set_facecolor('#f8f9fa')
    for nm, tr in trainers.items():
        c = colors[nm]
        axes[1, 0].plot(np.abs(np.diff(tr.vl_loss)), label=nm, color=c, lw=2)
        gap = np.array(tr.tr_acc) - np.array(tr.vl_acc)
        axes[1, 1].plot(gap, label=nm, color=c, lw=2)
    axes[1, 0].set_title('|ΔVal Loss|', fontsize=13); axes[1, 0].legend()
    axes[1, 0].grid(alpha=0.3); axes[1, 0].set_facecolor('#f8f9fa')
    axes[1, 1].set_title('Overfitting Gap (Train−Val Acc)', fontsize=13)
    axes[1, 1].axhline(0, color='k', lw=1, ls=':')
    axes[1, 1].legend(); axes[1, 1].grid(alpha=0.3); axes[1, 1].set_facecolor('#f8f9fa')
    plt.tight_layout()
    plt.savefig('outputs/figures/training_curves.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("[PLOT] training_curves.png ✓")


def plot_calibration_curves(results):
    n_models = len(results)
    fig, axes = plt.subplots(n_models, 3, figsize=(15, 5 * n_models))
    if n_models == 1:
        axes = axes[np.newaxis, :]
    fig.suptitle('Calibration Curves by Class', fontsize=15, fontweight='bold')
    for row, (nm, res) in enumerate(results.items()):
        for col, cls_name in enumerate(DX_NAMES):
            ax = axes[row, col]
            prob_true, prob_pred = res['calibration_curves'][cls_name]
            if prob_true is not None:
                ax.plot([0, 1], [0, 1], 'k--', lw=2, label='Perfect calibration')
                ax.plot(prob_pred, prob_true, 's-', lw=2, label=f'{nm} - {cls_name}')
                ax.set_xlabel('Mean predicted probability')
                ax.set_ylabel('Fraction of positives')
                ax.set_title(f'{nm} - {cls_name}')
                ax.legend(); ax.grid(alpha=0.3)
            else:
                ax.text(0.5, 0.5, 'Insufficient data', ha='center', va='center')
                ax.set_title(f'{nm} - {cls_name}')
    plt.tight_layout()
    plt.savefig('outputs/figures/calibration_curves.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("[PLOT] calibration_curves.png ✓")


def plot_precision_recall_curves(results):
    """Plot Precision-Recall curves for each class"""
    fig, axes = plt.subplots(1, 3, figsize=(15, 5))
    fig.suptitle('Precision-Recall Curves by Class', fontsize=14, fontweight='bold')
    
    for idx, cls_name in enumerate(DX_NAMES):
        for nm, res in results.items():
            y_true = (res['trues'] == idx).astype(int)
            y_score = res['probs'][:, idx]
            precision, recall, _ = precision_recall_curve(y_true, y_score)
            ap = average_precision_score(y_true, y_score)
            axes[idx].plot(recall, precision, label=f'{nm} (AP={ap:.3f})', lw=2)
        axes[idx].set_title(f'{cls_name}')
        axes[idx].set_xlabel('Recall')
        axes[idx].set_ylabel('Precision')
        axes[idx].legend()
        axes[idx].grid(alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('outputs/figures/pr_curves.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("[PLOT] pr_curves.png ✓")


def plot_regression_metrics(results):
    fig, ax = plt.subplots(figsize=(6, 5))
    models = []
    maes = []
    n_samples_list = []
    for nm, res in results.items():
        rm = res['reg_metrics']
        models.append(nm)
        maes.append(rm['MAE'] if not np.isnan(rm['MAE']) else 0)
        n_samples_list.append(rm['n_samples'])
    
    bars = ax.bar(models, maes, color=['#3498db', '#e74c3c'])
    ax.set_title('Next-Visit CDRSB Prediction MAE')
    ax.set_ylabel('MAE')
    ax.grid(alpha=0.3)
    for bar, n in zip(bars, n_samples_list):
        ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.01, f'n={n}', ha='center')
    plt.tight_layout()
    plt.savefig('outputs/figures/regression_metrics.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("[PLOT] regression_metrics.png ✓")


def plot_prognosis_metrics(results):
    """Plot prognosis metrics (Accuracy, F1, AUC)"""
    fig, ax = plt.subplots(figsize=(8, 5))
    
    models = list(results.keys())
    accs = [results[nm]['prognosis_accuracy'] for nm in models]
    f1s = [results[nm]['prognosis_f1'] for nm in models]
    aucs = [results[nm]['prognosis_auc'] for nm in models]
    
    x = np.arange(len(models))
    width = 0.25
    
    ax.bar(x - width, accs, width, label='Accuracy', color='#2ecc71')
    ax.bar(x, f1s, width, label='F1-Macro', color='#3498db')
    ax.bar(x + width, aucs, width, label='AUC', color='#e74c3c')
    
    ax.set_xticks(x)
    ax.set_xticklabels(models)
    ax.set_ylim(0, 1)
    ax.set_title('Next-Visit Prognosis Metrics')
    ax.set_ylabel('Score')
    ax.legend()
    ax.grid(alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('outputs/figures/prognosis_metrics.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("[PLOT] prognosis_metrics.png ✓")


def plot_comparison_table(results):
    rows = []
    for nm, res in results.items():
        rm = res['reg_metrics']
        rows.append({
            'Model': nm,
            'Accuracy': f"{res['accuracy']:.4f}",
            'Bal_Acc': f"{res['balanced_accuracy']:.4f}",
            'F1-Macro': f"{res['f1_macro']:.4f}",
            'MCC': f"{res['mcc']:.4f}",
            'AUC': f"{res['auc']:.4f}",
            'MAE_next': f"{rm['MAE']:.3f}" if not np.isnan(rm['MAE']) else 'nan',
            'RMSE_next': f"{rm['RMSE']:.3f}" if not np.isnan(rm['RMSE']) else 'nan',
            'N_samples': rm['n_samples'],
            'Prog_Acc': f"{res['prognosis_accuracy']:.3f}" if not np.isnan(res['prognosis_accuracy']) else 'nan',
            'Prog_F1': f"{res['prognosis_f1']:.3f}" if not np.isnan(res['prognosis_f1']) else 'nan',
            'Prog_AUC': f"{res['prognosis_auc']:.3f}" if not np.isnan(res['prognosis_auc']) else 'nan',
        })
    df = pd.DataFrame(rows)
    df.to_csv('outputs/results/comparison_table.csv', index=False)
    
    fig, ax = plt.subplots(figsize=(16, 3))
    ax.axis('off')
    tbl = ax.table(cellText=df.values, colLabels=df.columns, cellLoc='center', loc='center')
    tbl.auto_set_font_size(False); tbl.set_fontsize(9); tbl.scale(1.2, 2.2)
    for (r, c), cell in tbl.get_celld().items():
        if r == 0:
            cell.set_facecolor('#2c3e50')
            cell.set_text_props(color='white', fontweight='bold')
        elif r % 2 == 0:
            cell.set_facecolor('#ecf0f1')
        cell.set_edgecolor('#bdc3c7')
    ax.set_title('Model Comparison — All Metrics', fontsize=13, fontweight='bold', pad=20)
    plt.tight_layout()
    plt.savefig('outputs/figures/comparison_table.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("[PLOT] comparison_table.png ✓")
    return df


