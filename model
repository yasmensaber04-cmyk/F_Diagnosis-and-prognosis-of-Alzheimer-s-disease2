# 7. ADVANCED LOSS FUNCTIONS
# ─────────────────────────────────────────────────────────────────────────────
class AdaptiveFocalLoss(nn.Module):
    """Focal Loss with different gamma per class for better MCI detection"""
    def __init__(self, gamma_cn=1.0, gamma_mci=3.0, gamma_ad=1.5, alpha=None, ignore_index=-1):
        super().__init__()
        self.gammas = {0: gamma_cn, 1: gamma_mci, 2: gamma_ad}
        self.alpha = alpha
        self.ignore_index = ignore_index

    def forward(self, logits, targets):
        valid = targets != self.ignore_index
        if not valid.any():
            return torch.tensor(0., device=logits.device, requires_grad=True)
        
        logits = logits[valid]
        targets = targets[valid]
        
        ce_loss = F.cross_entropy(logits, targets, reduction='none', weight=self.alpha)
        pt = torch.exp(-ce_loss)
        
        # Apply different gamma per class
        gamma_t = torch.ones_like(targets, dtype=torch.float32)
        for cls, gamma in self.gammas.items():
            gamma_t[targets == cls] = gamma
        
        focal_loss = ((1 - pt) ** gamma_t) * ce_loss
        return focal_loss.mean()


class LabelSmoothingCrossEntropy(nn.Module):
    def __init__(self, smoothing=0.1, ignore_index=-1):
        super().__init__()
        self.smoothing = smoothing
        self.ignore_index = ignore_index

    def forward(self, logits, targets):
        valid = targets != self.ignore_index
        if not valid.any():
            return torch.tensor(0., device=logits.device, requires_grad=True)
        logits = logits[valid]
        targets = targets[valid]
        n_classes = logits.size(-1)
        log_probs = F.log_softmax(logits, dim=-1)
        with torch.no_grad():
            true_dist = torch.zeros_like(log_probs)
            true_dist.fill_(self.smoothing / (n_classes - 1))
            true_dist.scatter_(1, targets.unsqueeze(1), 1.0 - self.smoothing)
        return torch.mean(torch.sum(-true_dist * log_probs, dim=-1))


class HuberLoss(nn.Module):
    def __init__(self, delta=1.0):
        super().__init__()
        self.delta = delta

    def forward(self, pred, target):
        valid = ~torch.isnan(target)
        if not valid.any():
            return torch.tensor(0., device=pred.device, requires_grad=True)
        return F.huber_loss(pred[valid], target[valid], delta=self.delta)


