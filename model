class AdvancedPreprocessor:
    def __init__(self, max_seq_len=8):
        self.max_seq_len = max_seq_len
        self.dyn_scaler = StandardScaler()
        self.fitted = False

    def _available_dyn_cols(self, df):
        base_cols = [c for c in DYNAMIC_FEATURES if c in df.columns]
        interaction_cols = [c for c in INTERACTION_FEATURES if c in df.columns]
        return base_cols + interaction_cols

    def _handle_outliers_iqr(self, df, dyn_cols):
        print("[PREP] Handling outliers with IQR...")
        for col in dyn_cols:
            if col in df.columns:
                q1 = df[col].quantile(0.25)
                q3 = df[col].quantile(0.75)
                iqr_val = q3 - q1
                lower = q1 - 3.0 * iqr_val
                upper = q3 + 3.0 * iqr_val
                df[col] = df[col].clip(lower, upper)
        return df

    def _cubic_interpolation(self, df, dyn_cols):
        print("[PREP] Applying cubic spline interpolation...")
        df = df.sort_values(['RID', 'Month'])

        for col in dyn_cols:
            if col not in df.columns:
                continue
            def interpolate_patient(grp):
                months = grp['Month'].values
                values = pd.to_numeric(grp[col], errors='coerce').values
                valid_idx = ~np.isnan(values)
                if valid_idx.sum() < 2:
                    return pd.Series(values, index=grp.index).ffill().bfill()
                try:
                    f = interpolate.interp1d(
                        months[valid_idx], values[valid_idx],
                        kind='cubic', bounds_error=False, fill_value='extrapolate'
                    )
                    return pd.Series(f(months), index=grp.index)
                except:
                    return pd.Series(values, index=grp.index).interpolate(method='linear').ffill().bfill()

            df[col] = df.groupby('RID', group_keys=False).apply(interpolate_patient)
        return df

    def _add_delta_features(self, df, dyn_cols):
        print("[PREP] Computing delta features (rate of change)...")
        df = df.sort_values(['RID', 'Month'])
        delta_cols = []
        for col in dyn_cols:
            if col in df.columns:
                delta_name = f'{col}_delta'
                df[delta_name] = df.groupby('RID')[col].diff().fillna(0)
                delta_cols.append(delta_name)
        return df, delta_cols

    def _kalman_smoothing(self, df, dyn_cols):
        print("[PREP] Applying Kalman filtering...")
        df = df.sort_values(['RID', 'Month'])

        for col in dyn_cols:
            if col not in df.columns:
                continue
            def smooth_patient(grp):
                values = grp[col].values
                if len(values) < 2:
                    return pd.Series(values, index=grp.index)
                kf = KalmanFilter(dim_x=2, dim_z=1)
                kf.x = np.array([values[0], 0.])
                kf.F = np.array([[1., 1.], [0., 1.]])
                kf.H = np.array([[1., 0.]])
                kf.P *= 10.
                kf.R = 5.
                kf.Q = np.eye(2) * 0.1
                smoothed = []
                for z in values:
                    kf.predict()
                    kf.update(z)
                    smoothed.append(kf.x[0])
                return pd.Series(smoothed, index=grp.index)

            df[col] = df.groupby('RID', group_keys=False).apply(smooth_patient)
        return df

    def _time_delta(self, df):
        df = df.sort_values(['RID', 'Month'])
        df['time_delta'] = df.groupby('RID')['Month'].diff().fillna(0).astype(np.float32)
        return df

    def fit_transform(self, df):
        df = df.copy()
        dyn_cols = self._available_dyn_cols(df)
        print(f"[PREP] Dynamic features available: {len(dyn_cols)}")

        df_orig = df[dyn_cols].copy()

        df = self._handle_outliers_iqr(df, dyn_cols)
        df = self._cubic_interpolation(df, dyn_cols)
        df = self._kalman_smoothing(df, dyn_cols)
        df, delta_cols = self._add_delta_features(df, dyn_cols)

        for c in dyn_cols:
            if c in df.columns:
                df[f'{c}_miss'] = df_orig[c].isna().astype(np.float32)

        for c in dyn_cols + delta_cols:
            if c in df.columns:
                df[c] = df[c].fillna(df[c].median())

        df = self._time_delta(df)

        miss_cols = [f'{c}_miss' for c in dyn_cols if c in df.columns]
        all_dyn = dyn_cols + delta_cols + miss_cols + ['time_delta']

        scale_cols = dyn_cols + delta_cols
        if scale_cols:
            self.dyn_scaler.fit(df[scale_cols].values)
            df[scale_cols] = self.dyn_scaler.transform(df[scale_cols].values)

        self.fitted = True
        self.dyn_cols = dyn_cols
        self.delta_cols = delta_cols
        self.all_dyn = all_dyn

        print(f"[PREP] Total dynamic features: {len(all_dyn)}")
        return df

    def transform(self, df):
        df = df.copy()
        dyn_cols = self.dyn_cols
        delta_cols = self.delta_cols

        df_orig = df[dyn_cols].copy()

        df = self._handle_outliers_iqr(df, dyn_cols)
        df = self._cubic_interpolation(df, dyn_cols)
        df = self._kalman_smoothing(df, dyn_cols)
        df, _ = self._add_delta_features(df, dyn_cols)

        for c in dyn_cols:
            if c in df.columns:
                df[f'{c}_miss'] = df_orig[c].isna().astype(np.float32)

        for c in dyn_cols + delta_cols:
            if c in df.columns:
                df[c] = df[c].fillna(df[c].median())

        df = self._time_delta(df)

        scale_cols = dyn_cols + delta_cols
        if scale_cols:
            df[scale_cols] = self.dyn_scaler.transform(df[scale_cols].values)

        return df

    def build_sequences(self, df):
        """Build sequences with next-visit prediction only."""
        seqs = {}
        valid_next_count = 0
        total_sequences = 0
        
        for pid, grp in df.groupby('RID'):
            grp = grp.sort_values('Month').reset_index(drop=True)
            T = min(len(grp), self.max_seq_len)
            grp = grp.iloc[:T]

            dyn = grp[self.all_dyn].values.astype(np.float32)
            static = grp[STATIC_FEATURES].iloc[0].values.astype(np.float32)
            dx = grp['DX'].values.astype(np.int64)
            months = grp['Month'].values.astype(np.float32)
            td = grp['time_delta'].values.astype(np.float32)

            cdrsb_values = grp['CDRSB'].values.astype(np.float32)
            dx_values = grp['DX'].values.astype(np.int64)

            # Next-visit prediction
            fc_next = np.full(T, np.nan, dtype=np.float32)
            fd_next = np.full(T, -1, dtype=np.int64)
            
            for i in range(T - 1):
                time_gap = months[i + 1] - months[i]
                if time_gap <= 24:
                    fc_next[i] = cdrsb_values[i + 1]
                    fd_next[i] = dx_values[i + 1]
                    valid_next_count += 1
                total_sequences += 1

            seqs[pid] = dict(
                dynamic=dyn, static=static, dx_seq=dx,
                months=months, time_deltas=td,
                future_cdrsb=fc_next,
                future_dx=fd_next,
                seq_len=T, pid=pid
            )
        
        print(f"[PREP] Next-visit targets available: {valid_next_count} out of {total_sequences} ({100*valid_next_count/max(total_sequences,1):.1f}%)")
        return seqs


