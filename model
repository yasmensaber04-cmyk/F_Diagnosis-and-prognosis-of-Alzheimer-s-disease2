# 9. ENHANCED TRAINER
# ─────────────────────────────────────────────────────────────────────────────
class AdvancedTrainer:
    def __init__(self, model, device, cls_w=None, lr=3e-4,
                 epochs=100, patience=25, name='model',
                 use_sam=True, use_mixup=True, accum_steps=4):
        self.model = model
        self.device = device
        self.name = name
        self.patience = patience
        self.epochs = epochs
        self.use_sam = use_sam
        self.use_mixup = use_mixup
        self.accum_steps = accum_steps

        # Use adaptive focal loss
        self.focal = AdaptiveFocalLoss(gamma_mci=3.0, gamma_ad=1.5, alpha=cls_w)
        self.label_smooth = LabelSmoothingCrossEntropy(smoothing=0.1)
        self.huber = HuberLoss(delta=1.0)

        if use_sam:
            self.opt = SAM(model.parameters(), base_optimizer=torch.optim.AdamW,
                           lr=lr, weight_decay=1e-4)
        else:
            self.opt = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-4)

        self.sched = None
        self.best = float('inf')
        self.cnt = 0
        self.tr_loss = []
        self.vl_loss = []
        self.tr_acc = []
        self.vl_acc = []

    def _step(self, batch, train=True, use_mixup=False):
        dyn = batch['dynamic'].to(self.device)
        stat = batch['static'].to(self.device)
        mask = batch['mask'].to(self.device)
        td = batch['time_deltas'].to(self.device)
        dx = batch['dx_seq'].to(self.device)

        if train and use_mixup and self.use_mixup:
            dyn, dx_a, dx_b, lam = mixup_data(dyn, dx, alpha=0.2)
            stat_mixed, _, _, _ = mixup_data(stat, dx[:, 0], alpha=0.2)
            stat = stat_mixed

        cls_l, reg, dxp, _ = self.model(dyn, stat, mask, td)
        B, T, C = cls_l.shape

        if train and use_mixup and self.use_mixup:
            loss_a = self.label_smooth(cls_l.view(B * T, C), dx_a.view(B * T))
            loss_b = self.label_smooth(cls_l.view(B * T, C), dx_b.view(B * T))
            loss = lam * loss_a + (1 - lam) * loss_b
        else:
            if train:
                loss = self.label_smooth(cls_l.view(B * T, C), dx.view(B * T))
            else:
                loss = self.focal(cls_l.view(B * T, C), dx.view(B * T))

        # Next-visit loss (use all timesteps except last)
        fc = batch['future_cdrsb'].to(self.device)
        fd = batch['future_dx'].to(self.device)
        
        target_reg = fc[:, :-1].reshape(-1)
        target_dx = fd[:, :-1].reshape(-1)
        
        reg_expanded = reg.unsqueeze(1).expand(-1, T - 1).reshape(-1)
        dxp_expanded = dxp.unsqueeze(1).expand(-1, T - 1, -1).reshape(-1, C)
        
        valid_reg = ~torch.isnan(target_reg)
        if valid_reg.any():
            loss += 0.4 * self.huber(reg_expanded[valid_reg], target_reg[valid_reg])
        
        valid_dx = target_dx >= 0
        if valid_dx.any():
            if train:
                loss += 0.2 * self.label_smooth(dxp_expanded[valid_dx], target_dx[valid_dx])
            else:
                loss += 0.2 * self.focal(dxp_expanded[valid_dx], target_dx[valid_dx])

        preds = cls_l.argmax(-1).cpu().numpy().flatten()
        trues = dx.cpu().numpy().flatten()
        valid = trues >= 0
        acc = accuracy_score(trues[valid], preds[valid]) if valid.any() else 0.0
        return loss, acc

    def epoch(self, loader, train=True):
        self.model.train(train)
        losses, accs = [], []

        if train:
            self.opt.zero_grad()

        for i, batch in enumerate(loader):
            if train:
                loss, acc = self._step(batch, train=True, use_mixup=(i % 2 == 0))
                loss = loss / self.accum_steps
                loss.backward()

                if (i + 1) % self.accum_steps == 0:
                    if self.use_sam:
                        self.opt.first_step(zero_grad=True)
                        loss2, _ = self._step(batch, train=True, use_mixup=False)
                        loss2 = loss2 / self.accum_steps
                        loss2.backward()
                        self.opt.second_step(zero_grad=True)
                    else:
                        nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)
                        self.opt.step()
                        self.opt.zero_grad()

                    if self.sched is not None:
                        self.sched.step()

                losses.append(loss.item() * self.accum_steps)
                accs.append(acc)
            else:
                with torch.no_grad():
                    loss, acc = self._step(batch, train=False)
                    losses.append(loss.item())
                    accs.append(acc)

        return np.mean(losses), np.mean(accs)

    def fit(self, tr_ld, vl_ld):
        print(f"\n{'=' * 60}\n  Training: {self.name}\n{'=' * 60}")

        total_steps = len(tr_ld) * self.epochs // self.accum_steps
        self.sched = OneCycleLR(
            self.opt.base_optimizer if self.use_sam else self.opt,
            max_lr=3e-4, total_steps=total_steps, pct_start=0.3,
            anneal_strategy='cos', div_factor=25.0, final_div_factor=1e4
        )

        for ep in range(1, self.epochs + 1):
            tl, ta = self.epoch(tr_ld, train=True)
            vl, va = self.epoch(vl_ld, train=False)

            self.tr_loss.append(tl)
            self.vl_loss.append(vl)
            self.tr_acc.append(ta)
            self.vl_acc.append(va)

            if ep % 10 == 0 or ep == 1:
                print(f"  Ep {ep:3d} | Loss {tl:.4f}/{vl:.4f} | Acc {ta:.4f}/{va:.4f}")

            if vl < self.best:
                self.best = vl
                self.cnt = 0
                torch.save(self.model.state_dict(), f'outputs/models/{self.name}_best.pt')
            else:
                self.cnt += 1
                if self.cnt >= self.patience:
                    print(f"  [EarlyStopping] at epoch {ep}")
                    break

        self.model.load_state_dict(torch.load(f'outputs/models/{self.name}_best.pt', map_location=self.device))
        print(f"  Best val loss: {self.best:.4f}")


