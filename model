# 6. IMPROVED MODEL ARCHITECTURES WITH CROSS-ATTENTION
# ─────────────────────────────────────────────────────────────────────────────
class MultiHeadAttention(nn.Module):
    def __init__(self, d_model, n_heads=8, dropout=0.1):
        super().__init__()
        assert d_model % n_heads == 0
        self.d_model = d_model
        self.n_heads = n_heads
        self.d_k = d_model // n_heads
        self.q_linear = nn.Linear(d_model, d_model)
        self.k_linear = nn.Linear(d_model, d_model)
        self.v_linear = nn.Linear(d_model, d_model)
        self.out = nn.Linear(d_model, d_model)
        self.dropout = nn.Dropout(dropout)

    def forward(self, x, mask=None):
        B, T, D = x.shape
        Q = self.q_linear(x).view(B, T, self.n_heads, self.d_k).transpose(1, 2)
        K = self.k_linear(x).view(B, T, self.n_heads, self.d_k).transpose(1, 2)
        V = self.v_linear(x).view(B, T, self.n_heads, self.d_k).transpose(1, 2)
        scores = torch.matmul(Q, K.transpose(-2, -1)) / math.sqrt(self.d_k)
        if mask is not None:
            mask = mask.unsqueeze(1).unsqueeze(2)
            scores = scores.masked_fill(mask == 0, -1e9)
        attn = F.softmax(scores, dim=-1)
        attn = self.dropout(attn)
        out = torch.matmul(attn, V)
        out = out.transpose(1, 2).contiguous().view(B, T, D)
        out = self.out(out)
        return out, attn.mean(dim=1)


class CrossAttentionLayer(nn.Module):
    """Cross-attention بين الزيارات الحالية والسابقة"""
    def __init__(self, d_model, n_heads=4, dropout=0.1):
        super().__init__()
        self.cross_attn = nn.MultiheadAttention(d_model, n_heads, dropout=dropout, batch_first=True)
        self.norm = nn.LayerNorm(d_model)
        
    def forward(self, h, mask=None):
        # h: (B, T, D)
        attn_out, _ = self.cross_attn(h, h, h, key_padding_mask=~mask.bool() if mask is not None else None)
        return self.norm(h + attn_out)


class TransformerEncoderBlock(nn.Module):
    def __init__(self, d_model, n_heads=8, d_ff=512, dropout=0.1):
        super().__init__()
        self.attn = MultiHeadAttention(d_model, n_heads, dropout)
        self.norm1 = nn.LayerNorm(d_model)
        self.norm2 = nn.LayerNorm(d_model)
        self.ff = nn.Sequential(
            nn.Linear(d_model, d_ff), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(d_ff, d_model), nn.Dropout(dropout)
        )

    def forward(self, x, mask=None):
        attn_out, attn_weights = self.attn(x, mask)
        x = self.norm1(x + attn_out)
        ff_out = self.ff(x)
        x = self.norm2(x + ff_out)
        return x, attn_weights


class ResidualBiLSTM(nn.Module):
    def __init__(self, input_dim, hidden_dim, n_layers=2, dropout=0.3):
        super().__init__()
        self.n_layers = n_layers
        self.hidden_dim = hidden_dim
        self.lstm_layers = nn.ModuleList([
            nn.LSTM(input_dim if i == 0 else hidden_dim * 2,
                   hidden_dim, batch_first=True, bidirectional=True)
            for i in range(n_layers)
        ])
        self.layer_norms = nn.ModuleList([nn.LayerNorm(hidden_dim * 2) for _ in range(n_layers)])
        self.dropout = nn.Dropout(dropout)
        if input_dim != hidden_dim * 2:
            self.input_proj = nn.Linear(input_dim, hidden_dim * 2)
        else:
            self.input_proj = None

    def forward(self, x):
        out = x
        for i, (lstm, norm) in enumerate(zip(self.lstm_layers, self.layer_norms)):
            residual = out
            out, _ = lstm(out)
            out = self.dropout(out)
            if i > 0:
                out = out + residual
            elif self.input_proj is not None:
                out = out + self.input_proj(residual)
            out = norm(out)
        return out


class ImprovedBiLSTMModel(nn.Module):
    def __init__(self, dyn_dim, stat_dim, hidden=128, n_layers=2,
                 dropout=0.3, n_cls=3, n_transformer_layers=2):
        super().__init__()

        self.input_proj = nn.Sequential(
            nn.Linear(dyn_dim + 1, dyn_dim),
            nn.LayerNorm(dyn_dim), nn.GELU(), nn.Dropout(dropout * 0.5)
        )
        self.lstm = ResidualBiLSTM(dyn_dim, hidden, n_layers, dropout)
        
        # Cross-attention between visits
        self.cross_attn = CrossAttentionLayer(hidden * 2, n_heads=4, dropout=dropout)
        
        self.transformer_blocks = nn.ModuleList([
            TransformerEncoderBlock(hidden * 2, n_heads=8, d_ff=hidden * 4, dropout=dropout)
            for _ in range(n_transformer_layers)
        ])
        self.stat_emb = nn.Sequential(
            nn.Linear(stat_dim, 64), nn.LayerNorm(64), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(64, 32), nn.LayerNorm(32), nn.GELU()
        )
        
        # Per-timestep classification head
        self.cls_h = nn.Sequential(
            nn.Linear(hidden * 2, 128), nn.LayerNorm(128), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(128, 64), nn.LayerNorm(64), nn.GELU(), nn.Dropout(dropout * 0.5),
            nn.Linear(64, n_cls)
        )

        # Next-visit regression head (sequence-level)
        fdim = hidden * 2 + 32
        self.reg_h = nn.Sequential(
            nn.Linear(fdim, 128), nn.LayerNorm(128), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(128, 64), nn.LayerNorm(64), nn.GELU(), nn.Dropout(dropout * 0.5),
            nn.Linear(64, 1)
        )

        self.dxp_h = nn.Sequential(
            nn.Linear(fdim, 128), nn.LayerNorm(128), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(128, 64), nn.LayerNorm(64), nn.GELU(), nn.Dropout(dropout * 0.5),
            nn.Linear(64, n_cls)
        )

        self._attn_weights = None

    def forward(self, dyn, stat, mask, td):
        B, T, _ = dyn.shape
        x = self.input_proj(torch.cat([dyn, td.unsqueeze(-1)], -1))
        h = self.lstm(x)
        
        # Cross-attention between visits
        h = self.cross_attn(h, mask)
        
        attn_weights_list = []
        for transformer_block in self.transformer_blocks:
            h, attn_w = transformer_block(h, mask)
            attn_weights_list.append(attn_w)
        self._attn_weights = torch.stack(attn_weights_list).mean(0)
        
        # Classification: per timestep
        cls_logits = self.cls_h(h)
        
        # For regression: use last timestep
        last_h = h[:, -1, :]
        
        # Static embedding
        stat_emb = self.stat_emb(stat)
        
        # Fusion
        fused = torch.cat([last_h, stat_emb], -1)
        
        # Next-visit regression and prognosis
        reg = self.reg_h(fused).squeeze(-1)
        dxp = self.dxp_h(fused)
        
        return cls_logits, reg, dxp, self._attn_weights


class ImprovedTCNModel(nn.Module):
    def __init__(self, dyn_dim, stat_dim, ch=128, ks=3, n_layers=6, dropout=0.3, n_cls=3):
        super().__init__()
        self.proj = nn.Sequential(
            nn.Conv1d(dyn_dim + 1, ch, 1), nn.BatchNorm1d(ch), nn.GELU(), nn.Dropout(dropout * 0.5)
        )
        self.blocks = nn.ModuleList([
            self._make_causal_block(ch, ks, 2 ** i, dropout) for i in range(n_layers)
        ])
        
        # Cross-attention after TCN
        self.cross_attn = CrossAttentionLayer(ch, n_heads=4, dropout=dropout)
        
        self.transformer = TransformerEncoderBlock(ch, n_heads=8, d_ff=ch * 4, dropout=dropout)
        self.stat_emb = nn.Sequential(
            nn.Linear(stat_dim, 64), nn.LayerNorm(64), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(64, 32), nn.LayerNorm(32), nn.GELU()
        )
        
        # Per-timestep classification head
        self.cls_h = nn.Sequential(
            nn.Linear(ch, 128), nn.LayerNorm(128), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(128, 64), nn.GELU(), nn.Linear(64, n_cls)
        )
        
        # Next-visit regression head
        fdim = ch + 32
        self.reg_h = nn.Sequential(
            nn.Linear(fdim, 128), nn.LayerNorm(128), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(128, 64), nn.GELU(), nn.Linear(64, 1)
        )
        self.dxp_h = nn.Sequential(
            nn.Linear(fdim, 128), nn.LayerNorm(128), nn.GELU(), nn.Dropout(dropout),
            nn.Linear(128, 64), nn.GELU(), nn.Linear(64, n_cls)
        )
        self._attn_weights = None

    def _make_causal_block(self, ch, ks, dil, drop):
        pad = (ks - 1) * dil
        return nn.Sequential(
            nn.Conv1d(ch, ch, ks, dilation=dil, padding=pad), nn.BatchNorm1d(ch), nn.GELU(), nn.Dropout(drop),
            nn.Conv1d(ch, ch, ks, dilation=dil, padding=pad), nn.BatchNorm1d(ch), nn.GELU(), nn.Dropout(drop)
        )

    def forward(self, dyn, stat, mask, td):
        B, T, _ = dyn.shape
        x = torch.cat([dyn, td.unsqueeze(-1)], -1).permute(0, 2, 1)
        x = self.proj(x)
        for block in self.blocks:
            residual = x
            out = block(x)
            x = (out[:, :, :T] + residual) * 0.5
        h = x.permute(0, 2, 1)
        
        # Cross-attention
        h = self.cross_attn(h, mask)
        
        h, attn_w = self.transformer(h, mask)
        self._attn_weights = attn_w
        
        # Classification: per timestep
        cls_logits = self.cls_h(h)
        
        # For regression: use last timestep
        last_h = h[:, -1, :]
        
        # Static embedding
        stat_emb = self.stat_emb(stat)
        
        # Fusion
        fused = torch.cat([last_h, stat_emb], -1)
        
        # Next-visit regression and prognosis
        reg = self.reg_h(fused).squeeze(-1)
        dxp = self.dxp_h(fused)
        
        return cls_logits, reg, dxp, self._attn_weights


