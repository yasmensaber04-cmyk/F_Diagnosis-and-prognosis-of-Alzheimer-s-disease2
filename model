# 10. ENHANCED EVALUATOR WITH F1 & AUC
# ─────────────────────────────────────────────────────────────────────────────
class AdvancedEvaluator:
    def __init__(self, model, device):
        self.model = model
        self.device = device

    def evaluate(self, loader, mc_samples=20):
        self.model.eval()

        def enable_dropout(m):
            if type(m) == nn.Dropout:
                m.train()

        all_p, all_t, all_probs = [], [], []
        reg_p, reg_t, reg_std = [], [], []
        dxp_p, dxp_t, dxp_probs_all = [], [], []
        attn_acc = []

        with torch.no_grad():
            for batch in loader:
                dyn = batch['dynamic'].to(self.device)
                stat = batch['static'].to(self.device)
                mask = batch['mask'].to(self.device)
                td = batch['time_deltas'].to(self.device)
                dx = batch['dx_seq'].to(self.device)

                mc_cls_logits = []
                mc_reg = []
                mc_dxp = []

                for _ in range(mc_samples):
                    self.model.apply(enable_dropout)
                    cls_l, reg, dxp, aw = self.model(dyn, stat, mask, td)
                    mc_cls_logits.append(F.softmax(cls_l, dim=-1))
                    mc_reg.append(reg)
                    mc_dxp.append(F.softmax(dxp, dim=-1))

                cls_probs = torch.stack(mc_cls_logits).mean(0)
                B, T, C = cls_probs.shape
                p = cls_probs.argmax(-1).cpu().numpy().flatten()
                t = dx.cpu().numpy().flatten()
                probs = cls_probs.cpu().numpy().reshape(-1, C)

                valid = t >= 0
                all_p.extend(p[valid])
                all_t.extend(t[valid])
                all_probs.extend(probs[valid])
                attn_acc.append(aw.cpu().numpy())

                # Next-visit regression
                fc = batch['future_cdrsb'].to(self.device)
                fd = batch['future_dx'].to(self.device)
                
                target_reg = fc[:, :-1].reshape(-1)
                target_dx = fd[:, :-1].reshape(-1)
                
                reg_preds = torch.stack(mc_reg)
                reg_expanded = reg_preds.unsqueeze(2).expand(-1, -1, T - 1).reshape(mc_samples, -1)
                reg_mean = reg_expanded.mean(0)
                reg_uncertainty = reg_expanded.std(0)
                
                dxp_preds = torch.stack(mc_dxp)
                dxp_expanded = dxp_preds.unsqueeze(2).expand(-1, -1, T - 1, -1).reshape(mc_samples, -1, C)
                dxp_mean = dxp_expanded.mean(0)
                dxp_pred = dxp_mean.argmax(-1)
                
                valid_reg = ~torch.isnan(target_reg)
                if valid_reg.any():
                    reg_p.extend(reg_mean[valid_reg].cpu().numpy())
                    reg_t.extend(target_reg[valid_reg].cpu().numpy())
                    reg_std.extend(reg_uncertainty[valid_reg].cpu().numpy())
                
                valid_dx = target_dx >= 0
                if valid_dx.any():
                    dxp_p.extend(dxp_pred[valid_dx].cpu().numpy())
                    dxp_t.extend(target_dx[valid_dx].cpu().numpy())
                    dxp_probs_all.extend(dxp_mean[valid_dx].cpu().numpy())

        all_p = np.array(all_p)
        all_t = np.array(all_t)
        all_probs = np.array(all_probs)

        acc = accuracy_score(all_t, all_p)
        bal_acc = balanced_accuracy_score(all_t, all_p)
        f1 = f1_score(all_t, all_p, average='macro', zero_division=0)
        mcc = matthews_corrcoef(all_t, all_p)
        cm = confusion_matrix(all_t, all_p, labels=[0, 1, 2])
        rep = classification_report(all_t, all_p, target_names=DX_NAMES, zero_division=0)

        try:
            auc = roc_auc_score(all_t, all_probs, multi_class='ovr', average='macro')
        except:
            auc = np.nan

        # Prognosis metrics with F1 and AUC
        dxp_p = np.array(dxp_p) if dxp_p else np.array([])
        dxp_t = np.array(dxp_t) if dxp_t else np.array([])
        dxp_probs_all = np.array(dxp_probs_all) if dxp_probs_all else np.array([])
        
        if len(dxp_p) > 0:
            prognosis_acc = accuracy_score(dxp_t, dxp_p)
            prognosis_f1 = f1_score(dxp_t, dxp_p, average='macro', zero_division=0)
            prognosis_auc = roc_auc_score(dxp_t, dxp_probs_all, multi_class='ovr', average='macro') if len(np.unique(dxp_t)) > 1 else np.nan
        else:
            prognosis_acc = prognosis_f1 = prognosis_auc = np.nan

        # Calibration curves
        cal_curves = {}
        for cls in range(3):
            try:
                prob_true, prob_pred = calibration_curve(
                    all_t == cls, all_probs[:, cls], n_bins=10, strategy='uniform'
                )
                cal_curves[DX_NAMES[cls]] = (prob_true, prob_pred)
            except:
                cal_curves[DX_NAMES[cls]] = (None, None)

        # Regression metrics
        if reg_p:
            pp = np.array(reg_p)
            tt = np.array(reg_t)
            uu = np.array(reg_std)
            reg_metrics = {
                'MAE': mean_absolute_error(tt, pp),
                'RMSE': np.sqrt(mean_squared_error(tt, pp)),
                'mean_uncertainty': uu.mean(),
                'n_samples': len(pp)
            }
        else:
            reg_metrics = {'MAE': np.nan, 'RMSE': np.nan, 'mean_uncertainty': np.nan, 'n_samples': 0}

        # Attention weights
        max_T = max(a.shape[1] for a in attn_acc) if len(attn_acc) > 0 else 0
        pad_a = np.zeros((len(attn_acc), max_T))
        for i, a in enumerate(attn_acc):
            if a.ndim > 1:
                a_processed = a.mean(axis=0)
                if a_processed.ndim > 1:
                    a_processed = a_processed.mean(axis=0)
            else:
                a_processed = a
            curr_len = min(a_processed.shape[0], max_T)
            pad_a[i, :curr_len] = a_processed[:curr_len]
        attn_mean = pad_a.mean(0)

        return dict(
            accuracy=acc, balanced_accuracy=bal_acc, f1_macro=f1, mcc=mcc, auc=auc,
            confusion_matrix=cm, report=rep, calibration_curves=cal_curves,
            reg_metrics=reg_metrics,
            prognosis_accuracy=prognosis_acc,
            prognosis_f1=prognosis_f1,
            prognosis_auc=prognosis_auc,
            attn_weights=attn_mean, preds=all_p, trues=all_t, probs=all_probs
        )


